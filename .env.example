# MySQL Database Configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=fireguard

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key

# OTP hash secret untuk verifikasi OTP (generate random 32+ chars)
OTP_HASH_SECRET=your-super-secret-otp-key

# Aktif/nonaktif fallback login OTP untuk akun lama tanpa password_hash
AUTH_OTP_LOGIN_FALLBACK=true

# Gmail SMTP Configuration (untuk OTP dan notifikasi)
# 1. Aktifkan 2-Step Verification di akun Google
# 2. Buat App Password di https://myaccount.google.com/apppasswords
# 3. Gunakan App Password sebagai GMAIL_APP_PASSWORD
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# WhatsApp via Fonnte (Opsional - hanya jika ingin notifikasi via WA juga)
ENABLE_WHATSAPP=false
FONNTE_TOKEN=your_fonnte_token

# Node Environment
NODE_ENV=development

# Base URL untuk asset publik (wajib di production)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Android TWA / Play Store
ANDROID_PACKAGE_NAME=com.yourcompany.fireguard
ANDROID_SHA256_CERT_FINGERPRINT=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99
